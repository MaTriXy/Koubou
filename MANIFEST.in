# Include package source files
include src/koubou/*.py
recursive-include src/koubou *.py

# Include frame metadata (JSON only - PNGs downloaded on demand)
recursive-include src/koubou/frames *.json
include src/koubou/frames/*.json

# Exclude device frame PNGs (downloaded on demand)
recursive-exclude src/koubou/frames *.png
global-exclude *.png

# Include package metadata
include pyproject.toml
include LICENSE*
include README*
include MANIFEST.in